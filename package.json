{
  "name": "launchforge",
  "version": "1.0.0",
  "description": "AI-powered launch plan generator for SaaS founders and indie hackers",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "push": "tsx scripts/auto-push.ts",
    "agent:push": "tsx scripts/auto-push.ts \"auto: update launchforge\""
  },
  "dependencies": {
    "@marp-team/marp-core": "^4.3.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.10.0",
    "cheerio": "^1.2.0",
    "composio-core": "^0.5.39",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.1",
    "gifenc": "^1.0.3",
    "jsonwebtoken": "^9.0.3",
    "sharp": "^0.35.0",
    "uuid": "^11.0.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.25",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.10.2",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^10.0.0",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
