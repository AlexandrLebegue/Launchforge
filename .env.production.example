# ─────────────────────────────────────────────────────────────────────────────
# LaunchForge — Variables d'environnement PRODUCTION
# Copier vers .env sur le serveur :  cp .env.production.example .env
# NE JAMAIS committer .env (déjà dans .gitignore).
# ─────────────────────────────────────────────────────────────────────────────

# ── Auth (REQUIS) ─────────────────────────────────────────────────────────────
# Générer : openssl rand -hex 32
JWT_SECRET=

# ── IA — OpenRouter (REQUIS) ──────────────────────────────────────────────────
# https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/auto

# ── URL publique ──────────────────────────────────────────────────────────────
APP_URL=https://launchforge.alexandre-lebegue.com

# ── Administration (doit matcher VITE_ADMIN_EMAILS) ──────────────────────────
ADMIN_EMAILS=alexandrelebegue12@gmail.com
VITE_ADMIN_EMAILS=alexandrelebegue12@gmail.com

# ── Abonnement & facturation — Stripe (optionnel) ─────────────────────────────
# Active l'offre payante « Brasier ». Sans elles : essai + Braise marchent, le
# paiement affiche « bientôt ». Procédure complète : docs/BILLING.md.
# En PROD : utiliser des clés LIVE (sk_live_…) + un webhook LIVE pointant sur
# https://launchforge.alexandre-lebegue.com/api/billing/webhook
STRIPE_SECRET_KEY=
STRIPE_PRICE_MONTHLY=price_...
STRIPE_PRICE_ANNUAL=price_...
STRIPE_WEBHOOK_SECRET=whsec_...
# 'false' = lancement souple (personne n'est bridé). Défaut : true.
BILLING_ENFORCE_LIMITS=true

# ── Intégrations optionnelles ─────────────────────────────────────────────────
COMPOSIO_MCP_URL=
COMPOSIO_API_KEY=
COMPOSIO_PROXY_API_KEY=
TELEGRAM_BOT_TOKEN=
FREEIMAGE_API_KEY=
GITHUB_TOKEN=
IMAGE_MODEL=
LINKEDIN_VERSION=
