# ─────────────────────────────────────────────────────────────────────────────
# LaunchForge — Environment variables template
# Copy to .env and fill in your values:  cp .env.example .env
# NEVER commit .env — it is listed in .gitignore
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000

# ── Database ──────────────────────────────────────────────────────────────────
# Path for the SQLite file (Docker: /app/data/launchforge.db)
DB_PATH=./data/launchforge.db

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate a strong secret: openssl rand -hex 32
JWT_SECRET=change-me-use-openssl-rand-hex-32

# ── AI — OpenRouter ───────────────────────────────────────────────────────────
# Sign up and grab your key at https://openrouter.ai/keys
# Used for AI-powered plan generation (DeepSeek V3, GPT-4o, etc.)
OPENROUTER_API_KEY=sk-or-v1-...

# ── Composio (optional) ───────────────────────────────────────────────────────
# Required only for the auto-push agent feature
COMPOSIO_API_KEY=