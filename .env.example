# ─────────────────────────────────────────────────────────────────────────────
# LaunchForge — Environment variables template
# Copy to .env and fill in your values:  cp .env.example .env
# NEVER commit .env — it is listed in .gitignore
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000

# ── Database ──────────────────────────────────────────────────────────────────
# Path for the SQLite file (Docker: /app/data/launchforge.db)
DB_PATH=./data/launchforge.db

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate a strong secret: openssl rand -hex 32
JWT_SECRET=change-me-use-openssl-rand-hex-32

# ── Connexion Google (OAuth, optionnel) ───────────────────────────────────────
# Active le bouton « Continuer avec Google » sur les pages de connexion et
# d'inscription. Sans ces deux variables, le bouton n'apparaît pas.
# Création : Google Cloud Console → APIs & Services → Identifiants →
#   « Créer des identifiants » → ID client OAuth → type « Application Web ».
# URI de redirection autorisée à déclarer (doit correspondre EXACTEMENT) :
#   - Prod : https://VOTRE-DOMAINE/api/auth/google/callback
#   - Dev  : http://localhost:5173/api/auth/google/callback
# (l'app construit cette URI à partir de APP_URL ci-dessous)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── AI — OpenRouter ───────────────────────────────────────────────────────────
# Requis pour toute l'IA : onboarding, plans, assistant de contenu, agents.
# Clé sur https://openrouter.ai/keys — fonctionne avec n'importe quel modèle.
OPENROUTER_API_KEY=sk-or-v1-...
# Modèle (optionnel). Défaut : openrouter/auto (routage automatique).
# Exemples : anthropic/claude-sonnet-4.5, deepseek/deepseek-chat, openai/gpt-4o-mini
OPENROUTER_MODEL=openrouter/auto

# ── Composio MCP (optionnel) ──────────────────────────────────────────────────
# URL de votre serveur MCP Composio (dashboard.composio.dev → MCP).
# Active : publication réelle (manuelle ou automatique via le worker),
# synchro des métriques, scan boîte mail/réactions, envoi d'emails, et
# synchro des posts programmés vers votre calendrier personnel (Google/
# Outlook). Sans elle : copier-coller + saisie manuelle.
COMPOSIO_MCP_URL=https://mcp.composio.dev/...
# ── Bot Telegram (optionnel) ──────────────────────────────────────────────────
# Créez un bot via @BotFather sur Telegram et collez son token ici.
# Permet de piloter LaunchForge depuis un chat : état des activités, posts,
# validations, agents, rédaction de posts/emails, rappels.
TELEGRAM_BOT_TOKEN=

# ── URL publique de l'application (production) ────────────────────────────────
# Sert à construire les liens envoyés par email (réinitialisation de mot de
# passe). En dev, http://localhost:5173 est utilisé par défaut.
APP_URL=

# ── Administration (fondateurs) ───────────────────────────────────────────────
# Emails séparés par des virgules. Ces comptes accèdent au panneau /admin.
# La liste est lue au DÉMARRAGE du serveur (redémarrage requis après modif).
# Côté front, exposer aussi VITE_ADMIN_EMAILS pour afficher le lien dans la sidebar.
ADMIN_EMAILS=alexandrelebegue12@gmail.com
VITE_ADMIN_EMAILS=alexandrelebegue12@gmail.com

# ── Contournement LinkedIn (optionnel) ────────────────────────────────────────
# La version par défaut de l'outil LinkedIn de Composio épingle une version
# d'API périmée (erreur NONEXISTENT_VERSION). LaunchForge demande donc la
# version 'latest' de l'outil — rien à configurer. Si l'erreur revenait,
# deux secours automatiques/optionnels : l'outil legacy du serveur MCP
# (partage de lien : média du post, sinon APP_URL), puis — en posant ici une
# clé API « proxy execute » créée dans les réglages du projet Composio — la
# publication directe sur l'API LinkedIn (version réglable via
# LINKEDIN_VERSION, défaut 202506).
COMPOSIO_PROXY_API_KEY=
