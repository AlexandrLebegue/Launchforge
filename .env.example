# ─────────────────────────────────────────────────────────────────────────────
# LaunchForge — Environment variables template
# Copy to .env and fill in your values:  cp .env.example .env
# NEVER commit .env — it is listed in .gitignore
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000

# ── Database ──────────────────────────────────────────────────────────────────
# Path for the SQLite file (Docker: /app/data/launchforge.db)
DB_PATH=./data/launchforge.db

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate a strong secret: openssl rand -hex 32
JWT_SECRET=change-me-use-openssl-rand-hex-32

# ── AI — Anthropic (Claude) ───────────────────────────────────────────────────
# Required for the AI onboarding assistant and AI plan generation.
# Get a key at https://platform.claude.com/
# Without it, the app falls back to a manual form + template-based plans.
ANTHROPIC_API_KEY=sk-ant-...

# ── Composio (optional) ───────────────────────────────────────────────────────
# Required only for the auto-push agent feature
COMPOSIO_API_KEY=